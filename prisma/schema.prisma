// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql" // or "mysql"
}

model Supplier {
  id             String            @id @default(uuid())
  name           String
  contactName    String?
  phone          String?
  email          String?
  gstNumber      String?
  address        String?
  createdAt      DateTime          @default(now())
  balance        Decimal           @default(0.00) @db.Decimal(12, 2)
  openingBalance Decimal           @default(0.00) @db.Decimal(12, 2)
  // Relations
  purchases      Purchase[]
  payments       SupplierPayment[]
}

// 2. Updated Purchase Model (Linked to Supplier)

// 3. New SupplierPayment Model (To reduce balance)
model SupplierPayment {
  id            String   @id @default(uuid())
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  supplierId    String
  amount        Decimal  @db.Decimal(12, 2)
  paymentMode   String // e.g., Cash, Bank Transfer, UPI
  checkNo       String? // Optional, only for cheque payments
  transactionId String? // Optional, for non-cheque payments
  remarks       String? // Optional notes about the payment
  paymentDate   DateTime
  reference     String? // Cheque no, Transaction ID
  createdAt     DateTime @default(now())
}

model Product {
  id               String    @id @default(uuid())
  sku              String?   @unique
  name             String
  baseUnit         String // the atomic unit you stock in — always "Pcs" 
  currentSellPrice Decimal?  @db.Decimal(12, 2)
  taxRate          Decimal?  @db.Decimal(5, 2)
  isStockItem      Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  category         Category? @relation(fields: [categoryId], references: [id])
  categoryId       String?

  // relations
  priceHistory    ProductPriceHistory[]
  purchaseBatches PurchaseBatch[]
  saleLines       SaleLine[]
  unitConversions UnitConversion[]
}

model UnitConversion {
  id            String   @id @default(uuid())
  product       Product  @relation(fields: [productId], references: [id])
  productId     String
  unitName      String // "Case", "Ladi", "Pcs"
  conversionQty Int // how many base units (Pcs) = 1 of this unit
  createdAt     DateTime @default(now())

  @@unique([productId, unitName])
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Self-referential relation
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  // Relations
  products Product[]

  // Ensure name is unique within a parent scope
  @@unique([name, parentId])
}

model ProductPriceHistory {
  id            String   @id @default(uuid())
  product       Product  @relation(fields: [productId], references: [id])
  productId     String
  price         Decimal  @db.Decimal(12, 2) // selling price
  effectiveFrom DateTime // price effective from this datetime
  note          String?
  createdAt     DateTime @default(now())

  @@index([productId, effectiveFrom])
}

model Customer {
  id             String    @id @default(uuid())
  name           String
  phone          String?
  email          String?
  gstNumber      String?
  address        String?
  balance        Decimal   @default(0.00) @db.Decimal(12, 2)
  openingBalance Decimal   @default(0.00) @db.Decimal(12, 2) // New field for opening balance
  createdAt      DateTime  @default(now())
  town           String
  sales          Sale[]
  receipts       Receipt[]
}

model Purchase {
  id           String   @id @default(uuid())
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  supplierId   String
  invoiceNo    String?
  purchaseDate DateTime
  totalAmount  Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  batches PurchaseBatch[]
}

model PurchaseBatch {
  id              Int                   @id @default(autoincrement())
  product         Product               @relation(fields: [productId], references: [id])
  productId       String
  purchase        Purchase?             @relation(fields: [purchaseId], references: [id])
  purchaseId      String?
  qtyReceived     Int
  qtyRemaining    Int
  unitCost        Decimal               @db.Decimal(12, 2)
  receivedAt      DateTime              @default(now())
  sellingPrice    Decimal?              @db.Decimal(12, 2) // optional selling price for this batch
  mrp             Decimal               @db.Decimal(12, 2) // optional MRP for this batch
  saleAllocations SaleBatchAllocation[]
}

model Sale {
  id         String    @id @default(uuid())
  invoiceNo  String    @unique
  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?

  // ------------------ Customer details on sale for historical accuracy, even if they change later
  customerName    String? // snapshot of customer name at time of sale
  customerGST     String? // snapshot of customer GST number at time of sale
  customerPhone   String? // snapshot of customer phone number at time of sale
  customerAddress String? // snapshot of customer address at time of sale
  // ------------------
  saleDate        DateTime
  totalAmount     Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())

  lines SaleLine[]
}

model SaleLine {
  id        Int     @id @default(autoincrement())
  sale      Sale    @relation(fields: [saleId], references: [id])
  saleId    String
  product   Product @relation(fields: [productId], references: [id])
  productId String

  // We store the unit details on the line for historical accuracy, even if they change later
  qty      Int // Base unit quantity (in Pcs)
  unitQty  Int // the quantity in the unit sold (e.g., 1 Case = 12 Pcs, so unitQty=1, qty=12)
  unitname String // "Case", "Ladi", "Pcs" - for reference, not used in calculations  

  //----------product details
  productName   String // snapshot of product name at time of sale
  // We store the price details on the line for historical accuracy, even if they change later 
  unitSellPrice Decimal  @db.Decimal(12, 2) // the final price charged to customer
  taxRate       Decimal? @db.Decimal(5, 2)
  lineTotal     Decimal  @db.Decimal(12, 2)
  costAllocated Decimal  @db.Decimal(12, 2) // COGS for this line (sum of allocations)
  createdAt     DateTime @default(now())

  allocations SaleBatchAllocation[]
}

model SaleBatchAllocation {
  id              Int           @id @default(autoincrement())
  saleLine        SaleLine      @relation(fields: [saleLineId], references: [id])
  saleLineId      Int
  purchaseBatch   PurchaseBatch @relation(fields: [purchaseBatchId], references: [id])
  purchaseBatchId Int
  qtyAllocated    Int
  unitCost        Decimal       @db.Decimal(12, 2) // snapshot of the batch unit cost used
}

model Receipt {
  id          Int      @id @default(autoincrement())
  customer    Customer @relation(fields: [customerId], references: [id])
  customerId  String
  amount      Decimal  @db.Decimal(12, 2)
  paymentMode String
  receiptDate DateTime
  reference   String?
  createdAt   DateTime @default(now())
}
