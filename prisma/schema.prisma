generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id                   String    @id @default(uuid())
  email                String    @unique
  password             String
  name                 String?
  role                 String
  isOnboarded          Boolean   @default(false)
  isEmailVerified      Boolean   @default(false)
  lastLoginAt          DateTime?
  lastPasswordChangeAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  purchases        Purchase[]
  sales            Sale[]
  receipts         Receipt[]
  supplierPayments SupplierPayment[]
  products         Product[]
  suppliers        Supplier[]
  customers        Customer[]
  categories       Category[]
  refreshTokens    RefreshToken[]
  sessions         Session[]

  @@index([email])
  @@index([isEmailVerified])
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  user      user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  isRevoked Boolean   @default(false)
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessionId String // <-- link to session

  @@index([userId])
  @@index([expiresAt])
  @@index([isRevoked])
}

model Session {
  id             String    @id @default(uuid())
  user           user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  ipAddress      String?
  userAgent      String?
  isActive       Boolean   @default(true)
  lastActivityAt DateTime  @default(now())
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?

  @@index([userId])
  @@index([isActive])
  @@index([lastActivityAt])
}

model OtpVerification {
  id          String    @id @default(uuid())
  email       String
  otpHash     String
  otpExpiry   DateTime
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  isVerified  Boolean   @default(false)
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime

  @@unique([email, isVerified])
  @@index([email])
  @@index([expiresAt])
}

model Supplier {
  id             String   @id @default(uuid())
  name           String
  contactName    String?
  phone          String?
  email          String?
  gstNumber      String?
  address        String?
  createdAt      DateTime @default(now())
  balance        Decimal  @default(0.00) @db.Decimal(12, 2)
  openingBalance Decimal  @default(0.00) @db.Decimal(12, 2)
  createdBy      user     @relation(fields: [createdById], references: [id])
  createdById    String

  purchases Purchase[]
  payments  SupplierPayment[]
}

model SupplierPayment {
  id            String   @id @default(uuid())
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  supplierId    String
  amount        Decimal  @db.Decimal(12, 2)
  paymentMode   String
  checkNo       String?
  transactionId String?
  remarks       String?
  paymentDate   DateTime
  reference     String?
  createdAt     DateTime @default(now())
  createdBy     user     @relation(fields: [createdById], references: [id])
  createdById   String
}

model Product {
  id               String    @id @default(uuid())
  sku              String?   @unique
  name             String
  baseUnit         String
  currentSellPrice Decimal?  @db.Decimal(12, 2)
  taxRate          Decimal?  @db.Decimal(5, 2)
  isStockItem      Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  category         Category? @relation(fields: [categoryId], references: [id])
  categoryId       String?
  createdBy        user      @relation(fields: [createdById], references: [id])
  createdById      String

  priceHistory    ProductPriceHistory[]
  purchaseBatches PurchaseBatch[]
  saleLines       SaleLine[]
  unitConversions UnitConversion[]
}

model UnitConversion {
  id            String   @id @default(uuid())
  product       Product  @relation(fields: [productId], references: [id])
  productId     String
  unitName      String
  conversionQty Int
  createdAt     DateTime @default(now())

  @@unique([productId, unitName])
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  createdBy   user       @relation(fields: [createdById], references: [id])
  createdById String

  products Product[]

  @@unique([name, parentId])
}

model ProductPriceHistory {
  id            String   @id @default(uuid())
  product       Product  @relation(fields: [productId], references: [id])
  productId     String
  price         Decimal  @db.Decimal(12, 2)
  effectiveFrom DateTime
  note          String?
  createdAt     DateTime @default(now())

  @@index([productId, effectiveFrom])
}

model Customer {
  id             String   @id @default(uuid())
  name           String
  phone          String?
  email          String?
  gstNumber      String?
  address        String?
  balance        Decimal  @default(0.00) @db.Decimal(12, 2)
  openingBalance Decimal  @default(0.00) @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  town           String
  createdBy      user     @relation(fields: [createdById], references: [id])
  createdById    String

  sales    Sale[]
  receipts Receipt[]
}

model Purchase {
  id           String   @id @default(uuid())
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  supplierId   String
  invoiceNo    String?
  purchaseDate DateTime
  totalAmount  Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  createdBy    user     @relation(fields: [createdById], references: [id])
  createdById  String

  batches PurchaseBatch[]
}

model PurchaseBatch {
  id           String    @id @default(uuid())
  product      Product   @relation(fields: [productId], references: [id])
  productId    String
  purchase     Purchase? @relation(fields: [purchaseId], references: [id])
  purchaseId   String?
  qtyReceived  Int
  qtyRemaining Int
  unitCost     Decimal   @db.Decimal(12, 2)
  receivedAt   DateTime  @default(now())
  sellingPrice Decimal?  @db.Decimal(12, 2)
  mrp          Decimal   @db.Decimal(12, 2)

  saleAllocations SaleBatchAllocation[]
}

model Sale {
  id              String    @id @default(uuid())
  invoiceNo       String    @unique
  customer        Customer? @relation(fields: [customerId], references: [id])
  customerId      String?
  customerName    String?
  customerGST     String?
  customerPhone   String?
  customerAddress String?
  saleDate        DateTime
  totalAmount     Decimal   @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())
  createdBy       user      @relation(fields: [createdById], references: [id])
  createdById     String

  lines SaleLine[]
}

model SaleLine {
  id            String   @id @default(uuid())
  sale          Sale     @relation(fields: [saleId], references: [id])
  saleId        String
  product       Product  @relation(fields: [productId], references: [id])
  productId     String
  qty           Int
  unitQty       Int
  unitname      String
  productName   String
  unitSellPrice Decimal  @db.Decimal(12, 2)
  taxRate       Decimal? @db.Decimal(5, 2)
  lineTotal     Decimal  @db.Decimal(12, 2)
  costAllocated Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  allocations SaleBatchAllocation[]
}

model SaleBatchAllocation {
  id              String        @id @default(uuid())
  saleLine        SaleLine      @relation(fields: [saleLineId], references: [id])
  saleLineId      String
  purchaseBatch   PurchaseBatch @relation(fields: [purchaseBatchId], references: [id])
  purchaseBatchId String
  qtyAllocated    Int
  unitCost        Decimal       @db.Decimal(12, 2)
}

model Receipt {
  id          String   @id @default(uuid())
  customer    Customer @relation(fields: [customerId], references: [id])
  customerId  String
  amount      Decimal  @db.Decimal(12, 2)
  paymentMode String
  receiptDate DateTime
  remarks     String?
  createdAt   DateTime @default(now())
  createdBy   user     @relation(fields: [createdById], references: [id])
  createdById String
}
